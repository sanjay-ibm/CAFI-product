{
  "skill": {
    "name": "IBM Product Search",
    "description": "Search and retrieve IBM product information from the product catalog",
    "version": "1.0.0",
    "category": "Information Retrieval",
    "tags": ["IBM", "products", "search", "catalog", "SLC codes"],
    "icon": "search",
    "provider": {
      "name": "IBM CAFI Product Catalog",
      "url": "https://product-catalog-api-cfai.apps.ocp-ai-dev.cp.fyre.ibm.com"
    }
  },
  "api": {
    "type": "openapi",
    "version": "3.0.0",
    "spec_url": "./product-search-skill.yaml",
    "base_url": "https://product-catalog-api-cfai.apps.ocp-ai-dev.cp.fyre.ibm.com",
    "authentication": {
      "type": "none",
      "description": "No authentication required for public endpoints"
    }
  },
  "skills": [
    {
      "id": "search_products",
      "name": "Search IBM Products",
      "description": "Search for IBM products using product codes, names, or keywords",
      "operation_id": "searchProducts",
      "input_parameters": [
        {
          "name": "query",
          "type": "string",
          "required": true,
          "description": "Product name, code, or description to search for",
          "examples": [
            "IBM Cloud Pak for Data",
            "5737-H33",
            "WebSphere",
            "DB2"
          ]
        },
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "default": 10,
          "description": "Maximum number of results to return (1-100)"
        },
        {
          "name": "threshold",
          "type": "number",
          "required": false,
          "default": 0.70,
          "description": "Minimum match confidence score (0.0-1.0)"
        }
      ],
      "output": {
        "type": "object",
        "description": "Search results with matching products",
        "properties": {
          "query": "Original search query",
          "results": "Array of matching products with scores",
          "result_count": "Number of results found",
          "execution_time_ms": "Query execution time"
        }
      },
      "examples": [
        {
          "input": {
            "query": "Cloud Pak for Data"
          },
          "output": {
            "query": "Cloud Pak for Data",
            "results": [
              {
                "score": 1.0,
                "product_code": "5737-H33",
                "product_name": "IBM Cloud Pak for Data",
                "matched_aliases": ["cloud pak for data", "cp4d"]
              }
            ],
            "result_count": 1
          }
        }
      ]
    },
    {
      "id": "get_product_details",
      "name": "Get Product Details",
      "description": "Retrieve detailed information about an IBM product using its product code",
      "operation_id": "getProductByCode",
      "input_parameters": [
        {
          "name": "product_code",
          "type": "string",
          "required": true,
          "description": "IBM product code (SLC_CODE)",
          "examples": [
            "5737-H33",
            "5724-A12",
            "5655-Y04"
          ]
        }
      ],
      "output": {
        "type": "object",
        "description": "Product details",
        "properties": {
          "product_code": "IBM product code",
          "product_name": "Full product name"
        }
      },
      "examples": [
        {
          "input": {
            "product_code": "5737-H33"
          },
          "output": {
            "product_code": "5737-H33",
            "product_name": "IBM Cloud Pak for Data"
          }
        }
      ]
    }
  ],
  "deployment": {
    "environment": "cloud-prod",
    "region": "us-south",
    "orchestrate_api_url": "https://api.orchestrate.ibm.com",
    "skill_endpoint": "/v1/skills",
    "health_check": {
      "enabled": true,
      "endpoint": "/health",
      "interval_seconds": 300
    }
  },
  "metadata": {
    "created_date": "2026-04-21",
    "last_updated": "2026-04-21",
    "author": "CAFI Product Team",
    "support_contact": "cafi-support@ibm.com"
  }
}